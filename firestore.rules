rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'admin';
    }

    // User profiles. A user reads/updates only their own doc; admins read/write all.
    // SECURITY (CRITICAL-1): self-create só pode criar role == 'client' e não pode
    // forjar campos de confiança (role/affiliateId/isSpecial). O vínculo a um
    // affiliateId e a flag isSpecial são gravados SÓ pelo servidor (Admin SDK, que
    // ignora estas regras). O primeiro admin é semeado fora do cliente (console /
    // Admin SDK), nunca pelo fluxo de cadastro.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth.uid == userId
                    && request.resource.data.role == 'client'
                    && request.resource.data.uid == userId
                    && !('affiliateId' in request.resource.data.keys())
                    && !('isSpecial' in request.resource.data.keys());
      // O próprio usuário atualiza o doc, mas NÃO pode mudar role, o vínculo
      // (affiliateId) NEM a flag isSpecial — senão poderia se reapontar pra outro
      // afiliado (IDOR), se promover a admin, ou se auto-marcar especial e ganhar
      // acesso à /network e à sub-rede (R6). Esses três campos são server-only
      // (Admin SDK). Admin faz qualquer coisa.
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && request.resource.data.affiliateId == resource.data.affiliateId
            && request.resource.data.isSpecial == resource.data.isSpecial);
      allow delete: if isAdmin();
    }

    // Local mirror of the external affiliate list (synced by admins).
    match /affiliates/{affiliateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CPA / REV configuration per affiliate (taxas — dado comercial sensível).
    // SECURITY (R5): leitura mediada pelo servidor (Admin SDK, GET /api/affiliate-configs),
    // que escopa por papel (admin = todas; afiliado = própria + sub-rede do especial).
    // Cliente direto é BLOQUEADO — antes era `read: isSignedIn()` e qualquer afiliado
    // logado lia a coleção inteira (CPA/REV/byBrand de todos). Espelha payment_profiles.
    match /affiliate_configs/{affiliateId} {
      allow read, write: if isAdmin();
    }

    // Alias de e-mail -> affiliateId (Boost-first). Doc id = e-mail normalizado.
    // Guarda o e-mail (PII) dos afiliados nativos Boost e os vínculos manuais
    // (admin liga um e-mail de planilha a um afiliado existente). Mediado pelo
    // servidor (Admin SDK); cliente NUNCA lê e-mail de terceiro. Espelha affiliate_configs.
    match /affiliate_email_aliases/{emailKey} {
      allow read, write: if isAdmin();
    }

    // B3 · Afiliado especial: marca o especial + sub-rede + taxa da sub-rede.
    // Só o master (admin) escreve; leitura liberada a signed-in (o especial
    // precisa ler a própria sub-rede; escopo fino fica no proxy/servidor).
    match /special_affiliates/{affiliateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Global application settings (inclui settings/external_api, doc com FORMA de
    // credencial). SECURITY: leitura admin-only — antes era `read: isSignedIn()` e
    // qualquer afiliado logado lia o doc credential-shaped. Espelha o fix R5 de
    // affiliate_configs. O único leitor vivo é a tela Settings (admin); fetchSetting
    // do client é código morto. Escrita já era admin-only.
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Public contact form submissions: anyone may create; only admins may read/manage.
    // SECURITY (MEDIUM-2/LOW): o create anônimo é restrito ao shape esperado e a
    // tamanhos máximos — evita abuso de storage e injeção de conteúdo arbitrário no
    // painel admin. (Rate limit/captcha do formulário fica como follow-up — App Check.)
    match /contacts/{contactId} {
      allow create: if request.resource.data.keys().hasOnly(
                         ['name','email','phone','socialMedia','affiliateExperience','presentation','createdAt'])
                    && request.resource.data.name is string && request.resource.data.name.size() <= 120
                    && request.resource.data.email is string && request.resource.data.email.size() <= 200
                    && request.resource.data.phone is string && request.resource.data.phone.size() <= 40
                    && request.resource.data.socialMedia is string && request.resource.data.socialMedia.size() <= 120
                    && request.resource.data.affiliateExperience in ['sim', 'nao']
                    && request.resource.data.presentation is string && request.resource.data.presentation.size() <= 2000;
      allow read, update, delete: if isAdmin();
    }

    // Written/read server-side via the Admin SDK (which bypasses these rules).
    // Block direct client access except admins.
    match /affiliate_statuses/{statusId} {
      allow read, write: if isAdmin();
    }
    // APPEND-ONLY: o log é gravado SÓ pelo servidor (Admin SDK, que ignora estas
    // rules). O cliente admin pode LER a trilha, mas NÃO escrever/editar/apagar —
    // assim a auditoria não é adulterável nem pelo próprio admin. Antes era
    // `write: if isAdmin()`, o que deixava um admin forjar/remover logs pelo SDK do
    // cliente. [[boost-audit-trail]]
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // B4 · Dados de pagamento do afiliado (PIX/NF — PII). Lidos/gravados pelo
    // servidor via Admin SDK (que ignora estas regras); o afiliado acessa só o
    // próprio perfil pelos endpoints autenticados. Cliente direto é bloqueado;
    // admin pode ler direto.
    match /payment_profiles/{affiliateId} {
      allow read, write: if isAdmin();
    }

    // Link de divulgação da agência (/go/:code) + tracking de cliques. Tudo é
    // escrito/lido pelo servidor via Admin SDK (que ignora estas regras): o
    // /go/:code é público no servidor e o afiliado lê os próprios stats por
    // endpoint autenticado (/api/affiliate-links). Cliente direto é bloqueado;
    // admin pode ler direto. subid-ready p/ a atribuição por jogador (postback OTG).
    match /affiliate_links/{code} {
      allow read, write: if isAdmin();
    }
    match /link_clicks/{clickId} {
      allow read, write: if isAdmin();
    }
    match /link_click_stats/{statId} {
      allow read, write: if isAdmin();
    }

    // Backoffice de casas (betting houses). Registro próprio das casas (nome/logo/
    // brandId/registerUrlTemplate), gerido pelo admin via /casas. Escrito/lido pelo
    // servidor (Admin SDK, que ignora estas regras); o afiliado lê pelo GET
    // autenticado (/api/houses) p/ logos/filtros. Cliente direto é bloqueado; admin
    // pode ler/gerir direto.
    match /houses/{houseId} {
      allow read, write: if isAdmin();
    }

    // Resultados MANUAIS por casa (upload de planilha p/ casas 'manual'). Escrito/
    // lido pelo servidor (Admin SDK): o afiliado lê só as próprias linhas pelo GET
    // autenticado (/api/house-results), nunca o agregado/não-atribuído. Cliente
    // direto é bloqueado; admin pode ler/gerir direto.
    match /house_results/{rowId} {
      allow read, write: if isAdmin();
    }

    // Funil da v1 ANALÍTICA da OTG (cliques/cadastros/FTD/NGR por afiliado×casa —
    // inclui os só-funil que o relatório v2 esconde, ex.: "Lucas"). Escrito pelo
    // servidor (Admin SDK) no POST /api/analytics/refresh; o afiliado lê só o próprio
    // funil pelo GET autenticado (/api/affiliate-analytics, escopado por papel).
    // Cliente direto é bloqueado; admin pode ler/gerir direto. Espelha house_results.
    match /affiliate_analytics/{rowId} {
      allow read, write: if isAdmin();
    }

    // API keys de parceiros externos (M2M). Só o servidor (Admin SDK) emite/valida
    // — guarda o HASH da key, nunca a key crua. Cliente direto é bloqueado; admin
    // pode ler p/ gestão (vê só o hash + scopes). Ver server.ts (requirePartner).
    match /api_partners/{partnerId} {
      allow read, write: if isAdmin();
    }

    // Avisos / comunicados da rede (feed broadcast). O admin publica (via servidor,
    // requireAdmin); qualquer afiliado autenticado lê em tempo real. O filtro de
    // audiência (all/clients/specials) é aplicado no cliente — não é dado sensível,
    // só relevância. Escrita liberada a admin (o servidor usa Admin SDK; admin
    // direto também é permitido, espelhando affiliates/affiliate_configs).
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Mensagens diretas da gerência → afiliado (popup 1:1). Cada doc carrega o
    // `recipientUid` do destinatário; a leitura é escopada a ele (query segura:
    // resource.data.recipientUid == request.auth.uid). Escrita só pelo servidor
    // (Admin SDK ignora estas regras) — admin direto também é permitido. A
    // marca-leitura passa por endpoint autenticado (servidor valida o dono).
    match /direct_messages/{messageId} {
      allow read: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow write: if isAdmin();
    }

    // Notificações de SISTEMA por afiliado (ex.: "novos resultados na casa X" quando
    // o admin sobe um upload). Cada doc carrega o `recipientUid`; leitura escopada a
    // ele (query segura, mesmo padrão de direct_messages). Escrita SÓ pelo servidor
    // (Admin SDK ignora estas regras) — `write:false` trava qualquer cliente, inclusive
    // admin, já que o sistema é quem gera. [[boost-results-notification]]
    match /user_notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow write: if false;
    }

    // Ranking diário (snapshot calculado no servidor com a x-api-key da OTG, que o
    // afiliado não tem acesso pra montar sozinho). Doc id = data YYYY-MM-DD. Leitura
    // liberada a signed-in (leaderboard público com nomes — decisão de produto);
    // escrita só pelo servidor/admin.
    match /daily_rankings/{date} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Controle de versão da aplicação. O servidor (Admin SDK) publica app_meta/version
    // no boot de cada deploy; qualquer afiliado autenticado lê em tempo real p/ saber
    // se o bundle está desatualizado (banner de atualização + refresh). NÃO é dado
    // sensível (só o carimbo de versão/commit). Escrita só pelo servidor/admin.
    match /app_meta/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
