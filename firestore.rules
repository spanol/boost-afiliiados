rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'admin';
    }

    // User profiles. A user reads/updates only their own doc; admins read/write all.
    // SECURITY (CRITICAL-1): self-create só pode criar role == 'client' e não pode
    // forjar campos de confiança (role/affiliateId/isSpecial). O vínculo a um
    // affiliateId e a flag isSpecial são gravados SÓ pelo servidor (Admin SDK, que
    // ignora estas regras). O primeiro admin é semeado fora do cliente (console /
    // Admin SDK), nunca pelo fluxo de cadastro.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth.uid == userId
                    && request.resource.data.role == 'client'
                    && request.resource.data.uid == userId
                    && !('affiliateId' in request.resource.data.keys())
                    && !('isSpecial' in request.resource.data.keys());
      // O próprio usuário atualiza o doc, mas NÃO pode mudar role nem o vínculo
      // (affiliateId) — senão poderia se reapontar pra outro afiliado (IDOR) ou
      // se promover. Admin faz qualquer coisa.
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && request.resource.data.affiliateId == resource.data.affiliateId);
      allow delete: if isAdmin();
    }

    // Local mirror of the external affiliate list (synced by admins).
    match /affiliates/{affiliateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CPA / REV configuration per affiliate.
    match /affiliate_configs/{affiliateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // B3 · Afiliado especial: marca o especial + sub-rede + taxa da sub-rede.
    // Só o master (admin) escreve; leitura liberada a signed-in (o especial
    // precisa ler a própria sub-rede; escopo fino fica no proxy/servidor).
    match /special_affiliates/{affiliateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Global application settings.
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Public contact form submissions: anyone may create; only admins may read/manage.
    // SECURITY (MEDIUM-2/LOW): o create anônimo é restrito ao shape esperado e a
    // tamanhos máximos — evita abuso de storage e injeção de conteúdo arbitrário no
    // painel admin. (Rate limit/captcha do formulário fica como follow-up — App Check.)
    match /contacts/{contactId} {
      allow create: if request.resource.data.keys().hasOnly(
                         ['name','email','phone','instagram','affiliateExperience','presentation','createdAt'])
                    && request.resource.data.name is string && request.resource.data.name.size() <= 120
                    && request.resource.data.email is string && request.resource.data.email.size() <= 200
                    && request.resource.data.phone is string && request.resource.data.phone.size() <= 40
                    && request.resource.data.instagram is string && request.resource.data.instagram.size() <= 120
                    && request.resource.data.affiliateExperience in ['sim', 'nao']
                    && request.resource.data.presentation is string && request.resource.data.presentation.size() <= 2000;
      allow read, update, delete: if isAdmin();
    }

    // Written/read server-side via the Admin SDK (which bypasses these rules).
    // Block direct client access except admins.
    match /affiliate_statuses/{statusId} {
      allow read, write: if isAdmin();
    }
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // B4 · Dados de pagamento do afiliado (PIX/NF — PII). Lidos/gravados pelo
    // servidor via Admin SDK (que ignora estas regras); o afiliado acessa só o
    // próprio perfil pelos endpoints autenticados. Cliente direto é bloqueado;
    // admin pode ler direto.
    match /payment_profiles/{affiliateId} {
      allow read, write: if isAdmin();
    }

    // Link de divulgação da agência (/go/:code) + tracking de cliques. Tudo é
    // escrito/lido pelo servidor via Admin SDK (que ignora estas regras): o
    // /go/:code é público no servidor e o afiliado lê os próprios stats por
    // endpoint autenticado (/api/affiliate-links). Cliente direto é bloqueado;
    // admin pode ler direto. subid-ready p/ a atribuição por jogador (postback OTG).
    match /affiliate_links/{code} {
      allow read, write: if isAdmin();
    }
    match /link_clicks/{clickId} {
      allow read, write: if isAdmin();
    }
    match /link_click_stats/{statId} {
      allow read, write: if isAdmin();
    }
  }
}
